{
    "name": "@nxg-org/mineflayer-tracker",
    "version": "1.3.2",
    "description": "Provides functionality for more accurate entity and projectile tracking.",
    "keywords": [
        "mineflayer",
        "mineflayer-plugin",
        "mineflayer-tracker"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nxg-org/mineflayer-tracker.git"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "license": "GPL-3.0",
    "author": "generel_schwerz",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "require": "./lib/index.js",
            "default": "./lib/index.js"
        }
    },
    "files": [
        "lib/**/*",
        "example/**/*",
        "README*",
        "LICENSE*"
    ],
    "scripts": {
        "build": "npx tsc",
        "prepare": "npm run build",
        "prepublish": "npm run build",
        "test": "tsx --test test/**/*.test.ts",
        "extract:movement": "tsx scripts/extract-movement-samples.ts"
    },
    "dependencies": {
        "@nxg-org/mineflayer-physics-util": "link:C:\\Users\\owner\\Documents\\github\\mineflayer-physics-utils",
        "@nxg-org/mineflayer-trajectories": "^1.2.1",
        "@nxg-org/mineflayer-util-plugin": "^1.9.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.17",
        "minecraft-data": "^3.109.0",
        "mineflayer": "^4.27.0",
        "prismarine-block": "^1.23.0",
        "prismarine-entity": "^2.6.0",
        "prismarine-registry": "^1.12.0",
        "tsx": "^4.21.0",
        "typescript": "^5.8.3",
        "vec3": "^0.1.10"
    }
}
